# Copy this file to .env (or export these as real environment variables)
# and fill in your values. Never commit the real .env file.
# Bun loads .env automatically — no extra setup needed.

# Include the Jira context path if your instance is served under one (e.g. /jira).
JIRA_BASE_URL=https://its.ottobock.com/jira
JIRA_TOKEN=your-personal-access-token-here

# Optional: default project key for `jirac create`.
# Flag-driven: lets you omit --project. Wizard: pre-fills the project prompt.
JIRA_PROJECT=
